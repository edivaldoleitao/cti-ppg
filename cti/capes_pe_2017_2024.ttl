    capes:hasYear "2017"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/GILLIENE_BATISTA_FERREIRA_DA_COSTA> ;
    capes:isFromProgram <http://example.com/capes#program/ODONTOLOGIA> .

<http://example.com/capes#thesis/1036> a capes:Thesis ;
    capes:hasAbstract "IN DENTISTRY, THE INCREASED AESTHETIC REQUIREMENT REQUIRES A SOFT TISSUE ARCHITECTURE WITH AN INTACT PAPILLA AND A SYMMETRICAL GINGIVAL CONTOUR. IN ORDER TO EVALUATE THE FACTORS THAT INFLUENCE THE PRESENCE OR ABSENCE OF THE INTERPROXIMAL PAPILLA BETWEEN ADJACENT IMPLANTS, AND BETWEEN TOOTH AND IMPLANT, A RETROSPECTIVE CLINICAL STUDY WAS PERFORMED THROUGH CLINICAL AND RADIOGRAPHIC EVALUATION OF 44 PATIENTS REHABILITATED WITH 114 OSSEOINTEGRATED DENTAL IMPLANTS. THE NON-PROBABILISTIC SAMPLE COMPRI"@pt ;
    capes:hasDefenseDate "09FEB2017:00:00:00"^^xsd:date ;
    capes:hasTitle "\"FATORES QUE INFLUENCIAM A PRESENÇA OU A AUSÊNCIA DE PAPILA ENTRE IMPLANTES ADJACENTES E ENTRE DENTE E IMPLANTE"@pt ;
    capes:hasYear "2017"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/CAMILA_AGRA_SOUZA> ;
    capes:isFromProgram <http://example.com/capes#program/ODONTOLOGIA> .

<http://example.com/capes#thesis/1037> a capes:Thesis ;
    capes:hasAbstract "OBJECTIVE TO IDENTIFY RISK FACTORS FOR MAXILLARY OSTEONECROSIS IN CANCER PATIENTS SUBMITTED TO THE USE OF BISPHOSPHONATES. METHODS A CROSS-SECTIONAL DESCRIPTIVE STUDY WAS CONDUCTED WITH A SAMPLE OF 160 CANCER PATIENTS SUBMITTED TO BIFOSFONAT THERAPY. DATA WERE COLLECTED FROM THE INTERVIEW, CLINICAL EXAMINATION AND ANALYSIS OF PATIENTS' RECORDS. IN THE STATISTICAL ANALYSIS, THE COMPARISON OF THE PERCENTAGES FOUND IN THE LEVELS OF THE QUALITATIVE FACTORS WAS DONE BY THE CHI-SQUARE TEST FOR COMPARI"@pt ;
    capes:hasDefenseDate "23FEB2017:00:00:00"^^xsd:date ;
