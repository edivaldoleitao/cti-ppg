    capes:hasYear "2017"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/JODAVID_DE_ARAUJO_FERREIRA> ;
    capes:isFromProgram <http://example.com/capes#program/ESTATÍSTICA> .

<http://example.com/capes#thesis/10393> a capes:Thesis ;
    capes:hasAbstract "SYNTHETIC APERTURE RADAR (SAR) SYSTEMS HAVE BEEN PRESENTED LIKE EFFICIENT TOOLS IN SOLVING REMOTE SENSING PROBLEMS. SUCH SYSTEMS EXHIBIT SEVERAL ADVANTAGES. IN PARTICULAR, ITS OPERATION IS INDEPENDENT OF THE TIME OF DAY AND/OR ATMOSPHERE CONDITIONS, AS WELL AS THEY CAN PROVIDES IMAGES IN HIGH SPATIAL RESOLUTION. HOWEVER, SAR IMAGES ARE CONTAMINATED BY A TYPE OF INTERFERENCE CALLED SPECKLE NOISE, HINDERING THE RECOGNITION OF PATTERNS IN SUCH IMAGES BY VISUAL ANALYSIS AND/OR BY THE USE OF CLASSICA"@pt ;
    capes:hasDefenseDate "17FEB2017:00:00:00"^^xsd:date ;
