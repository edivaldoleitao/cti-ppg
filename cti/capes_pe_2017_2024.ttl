    capes:isAuthoredBy <http://example.com/capes#author/JACIANE_DE_ALMEIDA_COSTA> ;
    capes:isFromProgram <http://example.com/capes#program/PATOLOGIA> .

<http://example.com/capes#thesis/1258> a capes:Thesis ;
    capes:hasAbstract "THE OBJECTIVE OF THIS STUDY WAS TO EVALUATE THE ACTION OF BUPROPION / NALTREXONE ASSOCIATION ON WEIGHT, BIOCHEMICAL AND HISTOMORPHOMETRIC ASPECTS IN OBESE WISTAR RATS. WISTAR RATS WERE DIVIDED INTO TWO GROUPS ACCORDING TO THE DIET OFFERED: N = 10 NORMONUTRIDE (STANDARD VIVARIUM DIET) AND N = 10 OBESE (OBESITY-INDUCING DIET) AND THEN SUBDIVIDED INTO 4 GROUPS, WHERE N = 5 NORMONUTRIENTS. NO TREATMENT, N = 5 NORMONUTRIENTS TREATED WITH NAL / BUP COMBINATION, N = 5 OBESE WITHOUT TREATMENT AND N = 5 "@pt ;
    capes:hasDefenseDate "12SEP2019:00:00:00"^^xsd:date ;
    capes:hasTitle "EFEITOS DO TRATAMENTO COM A ASSOCIAÇÃO NALTREXONA/BUPROPIONA EM FÍGADOS DE RATOS OBESOS: ASPECTOS HISTOMORFOMÉTRICOS"@pt ;
