    capes:isFromProgram <http://example.com/capes#program/PROFBIO_ENSINO_DE_BIOLOGIA_EM_REDE_NACIONAL> .

<http://example.com/capes#thesis/23414> a capes:Thesis ;
    capes:hasAbstract "SEX EDUCATION HAS ALWAYS BEEN SEEN AS A TABOO BOTH IN SOCIETY AND SCHOOLS IN GENERAL. ON ONE HAND, DUE TO TRADITIONAL ISSUES RELATED TO RELIGION AND FAMILY EDUCATION. ON THE OTHER HAND, SOME EDUCATORS FEAR DISCUSSING CERTAIN MATTERS. IT MAKES CLASSES RELATED TO THE TOPIC FOCUS ON ITS CONCEPTUAL UNDERSTANDING, IMMERSING STUDENTS IN A WORLD FULL OF INFORMATION, BUT ALMOST ALWAYS WITHOUT ANY KNOWLEDGE OF RISKY SEXUAL BEHAVIORS, WHICH CAN RESULT IN SEXUALLY TRANSMITTED DISEASES (STIS) AND EVEN TEENA"@pt ;
    capes:hasDefenseDate "30AUG2022:00:00:00"^^xsd:date ;
    capes:hasTitle "PROTAGONIZANDO A APRENDIZAGEM SOBRE SEXUALIDADE HUMANA E COMPORTAMENTO SEXUAL DE RISCO, UMA PROPOSTA DE SEQUÊNCIA DIDÁTICA PARA O ENSINO MÉDIO"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
