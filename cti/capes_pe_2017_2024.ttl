    capes:isFromProgram <http://example.com/capes#program/GEOCIÊNCIAS> .

<http://example.com/capes#thesis/6797> a capes:Thesis ;
    capes:hasAbstract "THE MONITORING OF POTENTIOMETRIC SURFACE VARIATION AND WATER QUALITY IS AN ESSENTIAL ACTIVITY FOR UNDERSTANDING THE HYDRODYNAMIC BEHAVIOR OF AN AQUIFER. THE ABREU E LIMA REFINERY HAS BEEN MONITORING GROUNDWATER IN THE DOMAINS OF THEIR INSTALLATIONS SINCE MAY 2009. UNFORTUNATELY, THIS MONITORING WAS NOT CONTINUOUS, BUT THE VOLUME OF INFORMATION OBTAINED WAS SUBSTANTIAL, ESPECIALLY IN THE TWO YEARS OF AUTOMATIC MONITORING, WITH HOURLY RECORD OF THE WATER LEVEL. SIXTEEN CAMPAIGNS WERE PERFORMED TO "@pt ;
    capes:hasDefenseDate "14JUL2017:00:00:00"^^xsd:date ;
