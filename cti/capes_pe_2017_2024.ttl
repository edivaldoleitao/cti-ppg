    capes:isFromProgram <http://example.com/capes#program/CIÊNCIA_ANIMAL_TROPICAL> .

<http://example.com/capes#thesis/10684> a capes:Thesis ;
    capes:hasAbstract "OBESITY IS A CHRONIC DISEASE CHARACTERIZED BY THE EXCESSIVE ACCUMULATION OF BODY FAT DUE TO THE DIFFERENCE BETWEEN CONSUMPTION AND ENERGY EXPENDITURE. IT PRESENTS A MULTIFACTORIAL ETIOLOGY AND IS ASSOCIATED WITH OTHER COMORBIDITIES, SUCH AS HYPERTENSION, DIABETES MELLITUS, ATHEROSCLEROSIS, AND OBSTRUCTIVE SLEEP APNEA (OSAS). OSAS IS CONSIDERED A CHRONIC, PROGRESSIVE AND INCAPACITATING DISEASE WITH HIGH MORBIDITY AND MORTALITY. THE RESPIRATORY MUSCULATURE OF INDIVIDUALS WITH OSAS IS AFFECTED DUE "@pt ;
    capes:hasDefenseDate "06FEB2017:00:00:00"^^xsd:date ;
    capes:hasTitle "FUNÇÃO PULMONAR, FORÇA MUSCULAR RESPIRATÓRIA E CAPACIDADE FUNCIONAL DE EXERCÍCIO EM INDIVÍDUOS OBESOS COM A APNEIA OBSTRUTIVA DO SONO"@pt ;
