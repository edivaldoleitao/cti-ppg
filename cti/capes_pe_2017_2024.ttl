    capes:isAuthoredBy <http://example.com/capes#author/DIOGO_RODRIGUES_DE_ALMEIDA> ;
    capes:isFromProgram <http://example.com/capes#program/TECNOLOGIA_DA_ENERGIA> .

<http://example.com/capes#thesis/3728> a capes:Thesis ;
    capes:hasAbstract "GLOBAL CONSUMPTION OF MILK, CHEESE, AND DAIRY PRODUCTS HAS BEEN INCREASING IN RECENT YEARS, AND, CONSEQUENTLY, THE PRODUCTION OF WHEY, A MAJOR BY-PRODUCT OF THE DAIRY INDUSTRY, HAS INCREASED SIGNIFICANTLY. IN BRAZIL, MOST CHEESE MAKING INDUSTRIES ARE SMALL AND, THEREFORE, DO NOT HAVE A DEVELOPED TECHNOLOGY CAPABLE OF REUSING CHEESE WHEY. THIS STUDY AIMED TO ANALYZE THE VIABILITY OF BIOGAS PRODUCTION THROUGH REJECTS/RESIDUES FROM THE PRODUCTION CHAIN OF RENNET CHEESE ALONG WITH DAIRY COW MANURE. "@pt ;
    capes:hasDefenseDate "21DEC2017:00:00:00"^^xsd:date ;
