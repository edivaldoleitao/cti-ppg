PREFIX cti: <http://gic.ufrpe.br/cti/vocabulary/cti#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

SELECT ?instituicao (AVG(xsd:decimal(?conceito)) AS ?media)
WHERE {
  ?ppg a cti:PPG ;
       cti:sediado ?ict ;
       cti:avaliado ?avaliacao .

  ?ict cti:nm_entidade_ensino ?instituicao .

  ?avaliacao cti:cd_conceito_programa ?conceito .
}
GROUP BY ?instituicao
ORDER BY DESC(?media)