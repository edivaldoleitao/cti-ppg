    capes:isAuthoredBy <http://example.com/capes#author/WYLMA_DANUZZA_GUIMARAES_BASTOS> ;
    capes:isFromProgram <http://example.com/capes#program/ENFERMAGEM_-_FESP-UPE_-_UEPB> .

<http://example.com/capes#thesis/13472> a capes:Thesis ;
