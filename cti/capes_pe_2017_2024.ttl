    capes:isFromProgram <http://example.com/capes#program/ESTATÍSTICA> .

<http://example.com/capes#thesis/10398> a capes:Thesis ;
    capes:hasAbstract "INTRODUCED BY EFRON (1979), THE BOOTSTRAP BECAME AN IMPORTANT STATISTICAL TOOL, BEING USED TO OVERCOMING INFERENCE PROBLEMS ON SMALL SAMPLES OR WHEN THE ASYMPTOTIC THEORY IS INTRACTABLE. THE METHOD CAN BE USED, FOR EXAMPLE, IN THE CONSTRUCTION OF CONFIDENCE INTERVALS, BIAS CORRECTION OF ESTIMATORS AND HYPOTHESIS TESTING. IN THE BETA REGRESSION MODELS, PROPOSED IN FERRARI AND CRIBARI-NETO (2004) AND USED TO MODEL CONTINUOUS VARIABLES IN (0.1), THE METHOD HAS AN IMPORTANT ROLE IN THE CONSTRUCTION "@pt ;
    capes:hasDefenseDate "23FEB2017:00:00:00"^^xsd:date ;
    capes:hasTitle "INFERÊNCIA BOOTSTRAP EM MODELOS DE REGRESSÃO BETA"@pt ;
