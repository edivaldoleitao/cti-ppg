    capes:hasTitle "O NÚCLEO DE APOIO TÉCNICO AO JUDICIÁRIO EM PERNAMBUCO E A CONSOLIDAÇÃO DO SEU PAPEL COMO INSTÂNCIA DE DIÁLOGO INSTITUCIONAL ENTRE PODERES: UM CAMINHO PARA MINIMIZAR OS IMPACTOS PROVOCADOS PELA JUDICIALIZAÇÃO DA SAÚDE"@pt ;
    capes:hasYear "2020"^^xsd:gYear ;
