    capes:isFromProgram <http://example.com/capes#program/RECURSOS_PESQUEIROS_E_AQUICULTURA> .

<http://example.com/capes#thesis/27844> a capes:Thesis ;
    capes:hasAbstract "MACROBRACHIUM ROSENBERGII IS ONE OF THE MOST CULTIVATED FRESHWATER SPECIE IN THE WORLD, ITS CULTIVATION IS TRADITIONALLY CARRIED OUT IN SEMI-INTENSIVE SYSTEMS, HOWEVER, RECENT STUDIES HAVE DEMONSTRATED THE CAPACITY TO INCREASE THE STOCKING DENSITY OF FRESHWATER PRAWNS USING THE BIOFLOC SYSTEM . THE EXPERIMENT WAS CARRIED OUT FOR 58 DAYS AT THE AQUACULTURE STATION OF THE FEDERAL RURAL UNIVERSITY OF PERNAMBUCO, BRAZIL. JUVENILES OF 0.15 ± 0.001 G (375 PL M-3) WERE STORED IN EIGHT CIRCULAR TANKS (4"@pt ;
    capes:hasDefenseDate "26FEB2019:00:00:00"^^xsd:date ;
    capes:hasTitle "INFLUÊNCIA DO SISTEMA DE CULTIVO NA RESISTÊNCIA DE JUVENIS DE MACROBRACHIUM ROSENBERGII (DE MAN, 1879) À EXPOSIÇÃO AGUDA DE AMÔNIA"@pt ;
