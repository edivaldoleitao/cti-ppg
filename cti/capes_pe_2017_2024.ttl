    capes:isFromProgram <http://example.com/capes#program/ESTATÍSTICA> .

<http://example.com/capes#thesis/10399> a capes:Thesis ;
    capes:hasAbstract "IN THIS WORK WE EXTEND THE METHOD DEVELOPED BY MARTIN AND HAN (2016) FOR LINEAR REGRESSION MODELS (LRM-SMN) AND NONLINEAR REGRESSION MODELS (NLRM-SMN) IN SCALE MIXTURE OF NORMAL (SMN) DISTRIBUTIONS WITHOUT SPECIFYING A DISTRIBUTION FOR THE MIXTURE VARIABLE. ONE OF THE MAIN DRAWBACKS OF THE SMN SUBCLASS IS THAT IT ALLOWS PRACTITIONERS TO WORK WITH HEAVY TAILED DISTRIBUTIONS WHERE MAXIMUM LIKELIHOOD ESTIMATES ARE LESS SENSITIVE TO THE OUTLIERS. MARTIN AND HAN (2016) USE THE PREDICTIVE RECURSIVE (P"@pt ;
    capes:hasDefenseDate "23FEB2017:00:00:00"^^xsd:date ;
    capes:hasTitle "MODELOS DE REGRESSÃO SOB MISTURA DE ESCALA NORMAL: UM ENFOQUE NÃO PARAMÉTRICO PARA A VARIÁVEL DE MISTURA"@pt ;
