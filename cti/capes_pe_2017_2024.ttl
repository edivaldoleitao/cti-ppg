    capes:isFromProgram <http://example.com/capes#program/BIOCIÊNCIA_ANIMAL> .

<http://example.com/capes#thesis/23746> a capes:Thesis ;
    capes:hasAbstract "ETHANOL CONSUMPTION INCREASES OXIDATIVE STRESS IN THE BODY, IMPAIRING CELLULAR 147 PROCESSES AND ATTENUATING PLACENTAL DEVELOPMENT. SEVERAL INFLAMMATORY CYTOKINES ARE 148 IMPORTANT FOR THE CONTINUITY OF PREGNANCY AND CAN BE DEREGULATED AFTER ALCOHOL 149 INGESTION, LEADING TO IMPAIRED PLACENTAL PROGRESSION AND FETAL NUTRITIONAL LOSSES. 150 THEREFORE, MELATONIN HAS BEEN THE SUBJECT OF STUDIES DUE TO ITS POSSIBLE PROTECTIVE 151 EFFECT ON THE REGULATION OF INFLAMMATORY CYTOKINES AND TO REDUCE THE GE"@pt ;
    capes:hasDefenseDate "25FEB2022:00:00:00"^^xsd:date ;
    capes:hasTitle "AVALIAÇÃO DOS EFEITOS DA MELATONINA SOBRE ASPECTOS REPRODUTIVOS DE RATAS WISTAR SUBMETIDAS AO CONSUMO CRÔNICO DE ÁLCOOL"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/MARIA_VANESSA_DA_SILVA> ;
    capes:isFromProgram <http://example.com/capes#program/BIOCIÊNCIA_ANIMAL> .

