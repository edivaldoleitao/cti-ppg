    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/DANIELA_VIEIRA_DE_MENEZES> ;
    capes:isFromProgram <http://example.com/capes#program/GERONTOLOGIA> .

<http://example.com/capes#thesis/18777> a capes:Thesis ;
    capes:hasAbstract "THE RESEARCH AIMED TO IDENTIFY THE FACTORS THAT MAKE IT DIFFICULT TO QUIT SMOKING IN THE ELDERLY IN THE CITY OF JABOATÃO DOS GUARARAPES-PE, SEEKING TO UNDERSTAND THE POSSIBLE PSYCHOSOCIAL DETERMINANTS THAT CAN PREVENT SMOKING CESSATION IN THE ELDERLY UNDERGO- ING TREATMENT, IN ORDER TO POINT OUT STRATEGIES FOR CARE IN THE CARE OF ELDERLY SMOKERS, WHICH FACILITATE THE ADOPTION OF BEHAVIORS AIMED AT SMOKING CESSATION AND THE CONSE- QUENT IMPROVEMENT IN THE QUALITY OF LIFE OF THE POPULATION UNDER S"@pt ;
