    capes:isAuthoredBy <http://example.com/capes#author/KATIA_DA_FONSECA_RAMOS_ZAIDAN> ;
    capes:isFromProgram <http://example.com/capes#program/TECNOLOGIA_AMBIENTAL> .

<http://example.com/capes#thesis/20454> a capes:Thesis ;
    capes:hasAbstract "THE INTEGRATED REPORT (IR) IS A STATEMENT THAT GATHERS FINANCIAL AND NON-FINANCIAL INFORMATION, TO MEET THE NEW CHALLENGES AND OPPORTUNITIES OF THE CURRENT MOMENT AND HAS BECOME A WORLDWIDE STANDARD OF BUSINESS COMMUNICATION. COMPANIES IN THE ISE (CORPORATE SUSTAINABILITY INDEX) OF THE B3 STOCK EXCHANGE (BRASIL, BOLSA, BALCÃO) THAT HAVE ALREADY PASSED THE IMPLEMENTATION, GUIDANCE AND GUIDELINES OF THE GRI (GLOBAL REPORTING INITIATIVE) ARE ONE STEP AWAY FROM INTEGRATED REPORTING. THE GRI IS A TRU"@pt ;
    capes:hasDefenseDate "09FEB2022:00:00:00"^^xsd:date ;
    capes:hasTitle "RELATO INTEGRADO E INDICADORES GRI: UM ENFOQUE NA ESTRUTURA E NA CONTABILIDADE AMBIENTAL NO TERCEIRO SETOR"@pt ;
