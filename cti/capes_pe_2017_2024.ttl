    capes:isFromProgram <http://example.com/capes#program/TECNOLOGIA_DA_ENERGIA> .

<http://example.com/capes#thesis/1182> a capes:Thesis ;
    capes:hasAbstract "AIR-CONDITIONING SYSTEMS REPRESENT A SIGNIFICANT PORTION OF THE ENERGY CONSUMPTION OF SMALL, MEDIUM AND LARGE VEHICLES, IN THIS PERSPECTIVE, REFRIGERATION TECHNOLOGIES ARE BEING INCREASINGLY STUDIED IN ORDER TO IMPROVE THE ENERGY CONSUMPTION OF THIS EQUIPMENT. AMONG THESE TECHNOLOGIES, EJECTORS ARE MECHANISMS THAT AIM TO REDUCE CONSUMPTION BY INCREASING THE PERFORMANCE COEFFICIENT OF REFRIGERATION CYCLES. THE STUDY OF THE FLOW BEHAVIOR INSIDE THE EJECTOR IS COMPLEX, AND OFTEN, THE TEMPERATURE, P"@pt ;
    capes:hasDefenseDate "19DEC2019:00:00:00"^^xsd:date ;
