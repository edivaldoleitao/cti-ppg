    capes:isFromProgram <http://example.com/capes#program/ESTATÍSTICA> .

<http://example.com/capes#thesis/10396> a capes:Thesis ;
    capes:hasAbstract "THE ART OF PARAMETER INDUCTION TO A PARENT DISTRIBUTION IS ONE OF THE METHODS MORE USED FOR OBTAIN MORE VERSATILE MODELS. THE MAIN REASON FOR THIS TREND IS THE FACT THAT, MANY TIMES, CLASSIC MODELS OFTEN MAY NOT BE FLEXIBLE ENOUGH TO ADJUST CERTAIN LIFETIME DATA. SO, GENERALIZED OR EXTENDED DISTRIBUTIONS ARE OF GREAT IMPORTANCE, MAINLY FOR TWO REASONS: FOR CONTROLLING THE TAILS AND IMPROVE THE GOODNESS-OF-FIT OF THE PARENT DISTRIBUTION. IN THIS THESIS, WE PROPOSE TWO NEW FAMILIES OF DISTRIBUTION"@pt ;
    capes:hasDefenseDate "23JAN2017:00:00:00"^^xsd:date ;
    capes:hasTitle "GENERALIZED PROBABILITY DISTRIBUTIONS FOR LIFETIME APPLICATIONS"@pt ;
    capes:hasYear "2017"^^xsd:gYear ;
