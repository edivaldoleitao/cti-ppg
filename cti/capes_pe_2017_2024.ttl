    capes:hasTitle "DEFORMAÇÃO INTRACONTINENTAL NO INTERIOR DO TERRENO ALTO MOXOTÓ: CASO DE ESTUDO DA REGIÃO DE SUMÉ, PARAÍBA"@pt ;
