    capes:hasYear "2017"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/THAYGO_MARCAL_DA_MOTA> ;
    capes:isFromProgram <http://example.com/capes#program/CIÊNCIA_ANIMAL_TROPICAL> .

<http://example.com/capes#thesis/10683> a capes:Thesis ;
    capes:hasAbstract "BUFFALO BREEDING AND BUFFALO MILK PRODUCTION IN THE STATE OF PERNAMBUCO HAS BEEN NOTABLE FOR ITS EXCELLENT QUALITY AND NUTRITIONAL VALUE, THUS GENERATING A CHEESE WITH A HIGH FAT CONTENT, PROTEIN AND TOTAL SOLIDS, WITH GREATER CONSUMER ACCEPTABILITY, PRODUCT DURABILITY AND INDUSTRIAL PROFITS. THESE RESULTS ARE POSSIBLE DUE TO A CATTLE'S BALANCED DIET, ADEQUATE SANITARY MANAGEMENT AND GOOD HANDLING CONDITIONS DURING ITS MILKING PROCESS. THE MUZZARELLA CHEESE IS THE MAIN DAIRY PRODUCT FROM BUFFALO"@pt ;
    capes:hasDefenseDate "29MAY2017:00:00:00"^^xsd:date ;
