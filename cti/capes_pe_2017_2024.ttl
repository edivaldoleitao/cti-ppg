    capes:isFromProgram <http://example.com/capes#program/INOVAÇÃO_TERAPÊUTICA> .

<http://example.com/capes#thesis/6843> a capes:Thesis ;
    capes:hasAbstract "PROMOTING ACCESS TO ANTIRETROVIRAL TREATMENT BY HIV-INFECTED PATIENTS IS A WORLDWIDE PUBLIC HEALTH PRIORITY, SINCE WITHOUT ADEQUATE MEDICATION, PATIENTS BECOME HIGHLY VULNERABLE TO INFECTIONS. THUS, IT IS NECESSARY TO ENABLE ALTERNATIVES THAT INCREASE THERAPEUTIC COMPLIANCE AND, CONSEQUENTLY, THERAPEUTIC EFFICACY. ONE OF THE STRATEGIES USED IS THE SIMPLIFICATION OF THE THERAPEUTIC REGIMEN, THROUGH THE ASSOCIATION OF DRUGS IN A SINGLE PHARMACEUTICAL FORM. THEREFORE, RESEARCHERS FROM DRUG TECHNOLO"@pt ;
    capes:hasDefenseDate "13MAR2020:00:00:00"^^xsd:date ;
    capes:hasTitle "OTIMIZAÇÃO DE MÉTODO INDICATIVO DE ESTABILIDADE E PREDIÇÃO DO PRAZO DE VALIDADE DE COMPRIMIDO ASSOCIAÇÃO DOSE FIXA PARA O TRATAMENTO DE HIV"@pt ;
    capes:hasYear "2020"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/MARCOS_VICTOR_GREGORIO_DE_OLIVEIRA> ;
    capes:isFromProgram <http://example.com/capes#program/INOVAÇÃO_TERAPÊUTICA> .

<http://example.com/capes#thesis/6844> a capes:Thesis ;
    capes:hasAbstract "INFLAMMATION IS UNDERSTOOD AS THE BODY'S DEFENSE PROCESS AGAINST PATHOGENS AND ALTHOUGH IT IS A NATURAL RESPONSE, INFLAMMATION CAN TAKE HARMFUL TURNS ON ORGANISMS RESULTING IN DISEASE. THE INFLAMMATORY PROCESS IS ALSO SHOWN TO BE INVOLVED IN SEVERAL PATHOLOGIES, INCLUDING EPILEPSY. EPILEPSY IS THE RESULT OF AN IMBALANCE BETWEEN NEUROTRANSMITTERS, THE MAIN SYMPTOM OF WHICH IS SEIZURE, AFFECTING MILLIONS OF PEOPLE WORLDWIDE. THE MEDICAL TREATMENT OF THESE DISEASES IS ACCOMPANIED BY SEVERAL SIDE EF"@pt ;
    capes:hasDefenseDate "30JAN2020:00:00:00"^^xsd:date ;
    capes:hasTitle "SÍNTESE, CARACTERIZAÇÃO E AVALIAÇÃO DA ATIVIDADE ANTIINFLAMATÓRIA E ANTICONVULSIVANTE DE NOVOS DERIVADOS TIAZOFTALIMÍDICOS"@pt ;
