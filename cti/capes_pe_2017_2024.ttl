    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/ERIC_ALENCAR_LESSA> ;
    capes:isFromProgram <http://example.com/capes#program/REABILITAÇÃO_E_DESEMPENHO_FUNCIONAL> .

<http://example.com/capes#thesis/25985> a capes:Thesis ;
    capes:hasAbstract "BACKGROUND: THE USE OF MOBILE CELL PHONES HAS BECOME INCREASINGLY POPULAR IN THE DAILY LIFE OF OLDER PEOPLE AND IS ASSOCIATED WITH AN INCREASE IN EPISODES OF FALLS WHILE WALKING IN THIS POPULATION. DESPITE THE SCIENTIFIC LITERATURE PROVIDING IMPORTANT EVIDENCE ON THE NEGATIVE EFFECTS OF WALKING WHILE USING A CELL PHONE, ESPECIALLY IN YOUNG ADULTS, THERE IS STILL A LACK OF KNOWLEDGE ABOUT THE EFFECTS OF WALKING AND TALKING ON A CELL PHONE, ESPECIALLY REGARDING THE VARIABILITY OF SPACE-RELATED CHA"@pt ;
    capes:hasDefenseDate "16DEC2022:00:00:00"^^xsd:date ;
