    capes:isFromProgram <http://example.com/capes#program/ETNOBIOLOGIA_E_CONSERVAÇÃO_DA_NATUREZA> .

<http://example.com/capes#thesis/5691> a capes:Thesis ;
    capes:hasAbstract "THE SCARCITY OF ETHNOVETERINARY RESEARCH IN BRAZIL, ESPECIALLY IN THE NORTHEAST REGION, RESULTS IN LOSSES IN THE FIELD OF VETERINARY MEDICINE AND IN THE SCIENTIFIC DOCUMENTATION OF CULTURAL TRADITIONS ABOUT THE USE OF PLANTS IN THE TREATMENT OF DISEASES IN DOMESTIC ANIMALS. THIS STUDY AIMED TO CARRY OUT A SURVEY OF MEDICINAL PLANTS USED IN THE TREATMENT OF DOMESTIC ANIMALS IN A REGION OF THE NORTHEAST KNOWN AS THE CRAJUBAR TRIANGLE, LOCATED IN THE STATE OF CEARÁ, AND TO INDICATE THE SPECIES WITH"@pt ;
    capes:hasDefenseDate "20FEB2020:00:00:00"^^xsd:date ;
