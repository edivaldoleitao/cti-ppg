    capes:hasYear "2017"^^xsd:gYear,
        "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/ANA_PAULA_FERNANDES_DA_SILVA>,
        <http://example.com/capes#author/TUIRA_OLIVEIRA_MAIA> ;
    capes:isFromProgram <http://example.com/capes#program/DESIGN>,
