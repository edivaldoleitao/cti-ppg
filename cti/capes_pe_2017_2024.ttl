    capes:isFromProgram <http://example.com/capes#program/TECNOLOGIAS_ENERGÉTICAS_E_NUCLEARES> .

<http://example.com/capes#thesis/19539> a capes:Thesis ;
    capes:hasAbstract "THE ADVANCEMENT OF NANOTECHNOLOGY ENCOURAGES RESEARCHES TO DEVELOP INNOVATIVE SENSORS AND TECHNIQUES FOR MEASURING SEVERAL PHYSICAL QUANTITIES AND PROVIDING NEW APPLICATIONS, FOR EXAMPLE, THE DOSIMETRY IN RADIOTHERAPY. THE PURPOSE OF THIS WORK IS TO USE NANOFILMS OF ZINC AND MANGANESE OXIDE SEMICONDUCTORS FOR DOSIMETRIC APPLICATIONS IN RADIOTHERAPY PHOTON BEAM. SAMPLES OF NANOFILMS WERE MANUFACTURED BY SPUTTERING TECHNIQUE AND DEPOSITED ON A GLASS SUBSTRATE. TESTS IN A CLINICAL LINEAR ACCELERATO"@pt ;
    capes:hasDefenseDate "26FEB2019:00:00:00"^^xsd:date ;
