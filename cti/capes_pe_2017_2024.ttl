    capes:isAuthoredBy <http://example.com/capes#author/LEILA_GUILHERME_RIBEIRO_DO_VALLE> ;
    capes:isFromProgram <http://example.com/capes#program/DIREITO> .

<http://example.com/capes#thesis/21696> a capes:Thesis ;
    capes:hasAbstract "THIS WORK AIMS TO ANALYZE MEDIATION AS A MEANS OF EFFECTIVE IMPLEMENTATION OF INTERNATIONAL TRADE CONTRACTS. THE ANALYSIS SEEKS TO PROVIDE A CONTEXTUALIZATION OF THE NEW NEEDS PRESENTED BY INTERNATIONAL COMMERCIAL ACTORS IN THE FACE OF THE GLOBALIZED CONTEXT IN SOLVING CONFLICTS ARISING FROM INTERNATIONAL CONTRACTS. ALTERNATIVE MECHANISMS FOR RESOLVING PRIVATE CONFLICTS OUTSIDE OF THE JUDICIAL SYSTEM WERE PRESENTED, WITH AN EMPHASIS ON MEDIATION, WHICH IS THE MAIN FOCUS OF THIS STUDY. THROUGHOUT"@pt ;
    capes:hasDefenseDate "23SEP2022:00:00:00"^^xsd:date ;
