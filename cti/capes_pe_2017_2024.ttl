        "ASPECTOS AGRONÔMICO E ECONÔMICO-FINANCEIRA PARA O CULTIVO DE MALPIGHIA EMARGINATA D. C EM BIOMAS BRASILEIROS"@pt ;
    capes:hasYear "2019"^^xsd:gYear,
        "2022"^^xsd:gYear ;
