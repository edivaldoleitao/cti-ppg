    capes:isFromProgram <http://example.com/capes#program/ESTATÍSTICA> .

<http://example.com/capes#thesis/10392> a capes:Thesis ;
    capes:hasAbstract "AMONG THE REMOTE SENSING TECHNIQUES, THE POLSAR (POLARIMETRIC SYNTHETIC APERTURE RADAR) SYSTEM HAS RECEIVED A PROMINENT POSITION. THIS IS DUE TO ITS CAPABILITY IN (I) OPERATING IN VARIOUS WEATHER CONDITIONS (IN THE LIGHT ABSENCE, CLOUDY SCENARIOS, AMONG OTHERS), (II) PRODUCING IMAGES AT HIGH SPATIAL RESOLUTION, AND (III) PROVIDING INFORMATION ON A SCENE FROM POLARIZATION CHANNELS. HOWEVER, DATA OBTAINED FROM POLSAR IMAGES ARE STRONGLY CONTAMINATED BY A MULTIDIMENSIONAL INTERFERENCE PATTERN (CALL"@pt ;
    capes:hasDefenseDate "17FEB2017:00:00:00"^^xsd:date ;
