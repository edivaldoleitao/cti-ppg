    capes:isFromProgram <http://example.com/capes#program/BIOLOGIA_CELULAR_E_MOLECULAR_APLICADA> .

<http://example.com/capes#thesis/28472> a capes:Thesis ;
    capes:hasAbstract "CHAGAS DISEASE, CAUSED BY THE HEMOFLAGELLATE PROTOZOAN TRYPANOSOMA CRUZI, IS A NEGLECTED DISEASE FOR THE DEVELOPMENT OF ELIMINATION STRATEGIES, AND THEREFORE, FEW GOVERNMENT EFFORTS ARE DIRECTED IN THIS DIRECTION. ALLIED TO THIS, THE DRUGS AVAILABLE FOR TREATMENT ARE NOT VERY EFFECTIVE IN THE CHRONIC PHASE OF THE DISEASE, INDUCING NUMEROUS SIDE EFFECTS. IN THIS STUDY THE BIOLOGICAL ACTIVITY OF COMPOUNDS OBTAINED FROM ARTHROSPIRA PLATENSIS WERE EVALUATED AGAINST TRYPANOSOMA CRUZI AND HEALTHY HUMA"@pt ;
    capes:hasDefenseDate "24FEB2022:00:00:00"^^xsd:date ;
    capes:hasTitle "ATIVIDADE ANTIPARASITÁRIA DE COMPOSTOS BIOATIVOS OBTIDOS DA BIOMASSA DE ARTHROSPIRA PLATENSIS FRENTE ÀS FORMAS EVOLUTIVAS DO TRYPANOSOMA CRUZI"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/MARIA_RAFAELE_OLIVEIRA_BEZERRA_DA_SILVA> ;
    capes:isFromProgram <http://example.com/capes#program/BIOLOGIA_CELULAR_E_MOLECULAR_APLICADA> .

<http://example.com/capes#thesis/28473> a capes:Thesis ;
    capes:hasAbstract "TOXOPLASMA GONDI IS AN OBLIGATE PARASITE OF GREAT CLINICAL IMPORTANCE, WITH HIGHER PREVALENCE AND WIDE DISTRIBUTION, HOWEVER, IN ADDITION TO THE LIMITATION OF THERAPEUTIC ALTERNATIVES AVAILABLE FOR THE TREATMENT OF TOXOPLASMOSIS, A HIGH TOXICITY OF THE DRUGS USED IS ANOTHER FACTOR THAT IS PRESENT. AND AFFECTS THE QUALITY OF LIFE OF PATIENTS. THEREFORE, IT IS NECESSARY TO SEARCH FOR NATURALNESS WITH ANTI-TOXOPLASMA ACTIVITY FOR THE DEVELOPMENT OF NEW AND LESS TOXIC ACCESSORIES. THE AIM OF THIS ST"@pt ;
    capes:hasDefenseDate "29AUG2022:00:00:00"^^xsd:date ;
    capes:hasTitle "ATIVIDADE ANTIPARASITARIA IN VITRO DE COMPOSTOS BIOATIVOS OBTIDOS DA BIOMAS§A DE CHLORELLA VULGARIS FRENTE AO TOXAPLASMA GONDÍI"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/KARLLA_MAYARA_NUNES_DE_SOUSA> ;
    capes:isFromProgram <http://example.com/capes#program/BIOLOGIA_CELULAR_E_MOLECULAR_APLICADA> .

<http://example.com/capes#thesis/28474> a capes:Thesis ;
    capes:hasAbstract "OBESITY IS A MULTIFACTORIAL CHRONIC DISEASE, DEFINED BY EXCESS ADIPOSE TISSUE, CAUSED BY AN INTERACTION OF ENVIRONMENTAL AND GENETIC FACTORS, WHICH LEAD TO AN IMBALANCE IN ENERGY HOMEOSTASIS. THE SET OF THESE METABOLIC DISORDERS, CALLED METABOLIC SYNDROME (MS), INCLUDES INSULIN RESISTANCE, WHICH CULMINATES IN THE DEVELOPMENT OF TYPE 2 DIABETES MELLITUS (DM2). THERE IS A GROWING NUMBER OF ETHNOPHARMACOLOGICAL INVESTIGATIONS IN THE LITERATURE THAT DEMONSTRATE THE USE OF PLANT EXTRACTS AS A VIABLE "@pt ;
    capes:hasDefenseDate "27OCT2022:00:00:00"^^xsd:date ;
    capes:hasTitle "AVALIAÇÃO DA ATIVIDADE METABÓLICA DO EXTRATO DE PAU-FERRO [LIBIDIBIA FERREA (MART. EX TUL.) L P QUEIROZ VAR. FERREA] PADRÃO E MICORRIZADO EM CAMUNDONGOS OBESOS INDUZIDOS POR DIETA HIPERLIPÍDICA"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
