    capes:isFromProgram <http://example.com/capes#program/REABILITAÇÃO_E_DESEMPENHO_FUNCIONAL> .

<http://example.com/capes#thesis/25983> a capes:Thesis ;
    capes:hasAbstract "SYSTEMIC ARTERIAL HYPERTENSION (SAH) IS OFTEN ASSOCIATED WITH PEOPLE WITH DIABETES MELLITUS (DM). HOWEVER, AEROBIC EXERCISE HAS BECOME AN EFFECTIVE NON-PHARMACOLOGICAL TOOL FOR CONTROLLING, IN ADDITION TO BIOCHEMICAL PARAMETERS, CARDIORESPIRATORY VARIABLES, SUCH AS SYSTOLIC AND DIASTOLIC BLOOD PRESSURE (BP) RESPONSES IN THIS POPULATION GROUP. DESPITE THIS, THE LITERATURE DOES NOT SYNTHESIZE RESULTS REGARDING POST-EXERCISE HYPOTENSION (PEH) AFTER AEROBIC EXERCISES WITH DIFFERENT REST INTERVALS IN"@pt ;
    capes:hasDefenseDate "02DEC2022:00:00:00"^^xsd:date ;
    capes:hasTitle "COMPARAÇÃO DA RESPOSTA HIPOTENSORA DA PRESSÃO ARTERIAL CLÍNICA E RESIDENCIAL ENTRE UMA SESSÃO DE EXERCÍCIO AERÓBICO CONTÍNUO E INTERVALADO EM PACIENTES COM DIABETES MELLITUS TIPO 1"@pt ;
