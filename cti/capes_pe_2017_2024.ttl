    capes:isFromProgram <http://example.com/capes#program/TECNOLOGIAS_ENERGÉTICAS_E_NUCLEARES> .

<http://example.com/capes#thesis/19547> a capes:Thesis ;
    capes:hasAbstract "ALTHOUGH THE 18F-FDG RADIOPHARMACEUTICAL IS UNDOUBTEDLY A VERY USEFUL TOOL IN EARLY DETECTING TUMOR PROCESSES, ITS NON-SPECIFICITY FOR TUMORS, INFECTIONS AND INFLAMMATIONS CAN LEAD TO FALSE POSITIVES OR FALSE NEGATIVES, WHICH WILL HAVE A DIRECT IMPACT ON PATIENTS' QUALITY OF LIFE SUBMITTED TO PET/CT EXAMS. THUS, THE USE OF NANOCARRIERS FOR TUMOR'S DIAGNOSTIC,AS FOR EXAMPLE LIPOSOMES, IS AN INTERESTING TOOL FOR DELIVERY OF THE DRUG TO THE TARGET. THE ENCAPSULATION OF DRUGS IN LIPOSOMES CAN ALTER "@pt ;
    capes:hasDefenseDate "02AUG2019:00:00:00"^^xsd:date ;
    capes:hasTitle "ENCAPSULAÇÃO DE RADIOTRAÇADOR EM LIPOSSOMAS PH-SENSÍVEIS DE CIRCULAÇÃO PROLONGADA PARA IMAGENS PET/CT"@pt ;
