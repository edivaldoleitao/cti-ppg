    capes:isAuthoredBy <http://example.com/capes#author/JORGE_JOSE_DE_MEDEIROS_SOUZA> ;
    capes:isFromProgram <http://example.com/capes#program/TECNOLOGIA_AMBIENTAL> .

<http://example.com/capes#thesis/20450> a capes:Thesis ;
    capes:hasAbstract "GIVEN THE MANY DEVELOPMENTS WITH DEVICES THAT FACILITATE THE WAY OF LIFE, THE BENEFITS THEY HAVE BROUGHT HAVE CONTRIBUTED TO A NUMBER OF DIFFICULTIES OF HOW TO DEAL WITH THESE GADGETS AFTER BREAKAGE OR END OF LIFE OF THE LINE, WHERE IT WOULD BE DEPOSITED AND WHAT THE PROPER COURSE, WITHOUT PROCESSING DAMAGE OR HARM TO THE SUSTAINABLE ENVIRONMENT. GIVEN THIS CONTEXT, THE GENERAL OBJECTIVE OF THIS WORK WAS TO IDENTIFY HOW THE COURT OFFICIALS OF THE COURT OF JUSTICE OF PERNAMBUCO - TJPE, STATIONED "@pt ;
    capes:hasDefenseDate "14JUN2022:00:00:00"^^xsd:date ;
    capes:hasTitle "DESTINAÇÃO DOS RESÍDUOS ELETROELETRÔNICOS RESIDENCIAIS: UMA ANÁLISE BIBLIOMÉTRICA E DA PERCEPÇÃO DOS OFICIAIS DE JUSTIÇA DA CEMANDO RECIFE-PE"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/SERGIO_DE_OLIVEIRA_LIMA> ;
    capes:isFromProgram <http://example.com/capes#program/TECNOLOGIA_AMBIENTAL> .

<http://example.com/capes#thesis/20451> a capes:Thesis ;
    capes:hasAbstract "THE SCARCITY OF POTABLE WATER AND THE GROWING DEMAND FOR THIS NATURAL RESOURCE, ESSENTIAL FOR THE SURVIVAL OF ALL HUMAN BEINGS, ARE CONCERNS AROUND THE WORLD. IN BRAZIL, OTHER FACTORS HAVE BEEN ADDED TO THESE CONCERNS, SUCH AS THE POLLUTION OF OUR RIVERS AND SPRINGS, WHERE WATER FROM DOMESTIC SEWAGE, INDUSTRIAL AND AGRICULTURAL ACTIVITIES IS DISCHARGED DAILY, DUE TO THE SLURRY GENERATED BY GARBAGE DISPOSED OF IRREGULARLY IN THE OPEN AIR, FACTS MAINLY DUE TO THE LACK OF BASIC SANITATION, THE POOR"@pt ;
    capes:hasDefenseDate "17FEB2022:00:00:00"^^xsd:date ;
    capes:hasTitle "ESTAÇÃO DE TRATAMENTO DE EFLUENTES NO REAPROVEITAMENTO DE ÁGUA EM UM ÓRGÃO PÚBLICO: UMA ANÁLISE DA PERCEPÇÃO E DOS CUSTOS"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/CONSUELO_MARIA_PEREIRA_DE_AZEVEDO> ;
    capes:isFromProgram <http://example.com/capes#program/TECNOLOGIA_AMBIENTAL> .

<http://example.com/capes#thesis/20452> a capes:Thesis ;
    capes:hasAbstract "THE STRATEGIC PLANNING FOR THE 2021/2026 PERIOD OF THE TJPE REAFFIRMS THE CONSTANT MISSION OF DISSEMINATING AND ASSISTING IN THE PROCESS OF IMPLEMENTING THE UNITED NATIONS (UN) 2030 AGENDA FOR SUSTAINABLE DEVELOPMENT, RELATED TO THE COMMITMENTS TO THE SUSTAINABLE DEVELOPMENT GOALS (SDGS). FROM THIS PERSPECTIVE, IN 2017, THE TJPE SIGNED CONTRACTS WITH COLLECTORS' COOPERATIVES, AIMING AT THE SELECTIVE COLLECTION OF RECYCLABLE SOLID WASTE REGULARLY DISCARDED BY THE RODOLFO AURELIANO COURT JUDGE FOR"@pt ;
    capes:hasDefenseDate "07JUN2022:00:00:00"^^xsd:date ;
    capes:hasTitle "GESTÃO DOS RESÍDUOS SÓLIDOS RECICLÁVEIS: UM ESTUDO DE CASO NA PARCERIA DE UMA COOPERATIVA COM UM PRÉDIO PÚBLICO"@pt ;
