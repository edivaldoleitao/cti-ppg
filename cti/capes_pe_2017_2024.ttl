    capes:isFromProgram <http://example.com/capes#program/BIOLOGIA_VEGETAL> .

<http://example.com/capes#thesis/17222> a capes:Thesis ;
    capes:hasAbstract "THE CENTROMERE IS ESSENTIAL FOR GENOME STABILITY BY MEDIATING MITOTIC AND MEIOTIC SEGREGATION. CHROMOSOMES WITH A LOCALIZED CENTROMERE ARE CALLED MONOCENTRIC, WHILE THOSE WITH DIFFUSE CENTROMERES ALONG THE CHROMOSOMES ARE CALLED HOLOCENTRIC. RECENTLY, IT WAS DISCOVERED THAT SPECIES FROM THE CYPERID CLADE (CYPERACEAE, JUNCACEAE, AND THURNIACEAE) ALSO HAVE MONOCENTRIC CHROMOSOMES. IN THE FIRST CHAPTER, WE CONDUCTED NOVEL CHROMOSOMAL COUNTS FOR CYPERACEAE AND THURNIACEAE SPECIES, DETECTING RELATIVE"@pt ;
    capes:hasDefenseDate "22AUG2022:00:00:00"^^xsd:date ;
    capes:hasTitle "EVOLUÇÃO E ESTRUTURA CROMOSSÔMICA EM ESPÉCIES DO CLADO CYPERID"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/YHANNDRA_KARINE_DIAS_SILVA> ;
    capes:isFromProgram <http://example.com/capes#program/BIOLOGIA_VEGETAL> .

<http://example.com/capes#thesis/17223> a capes:Thesis ;
    capes:hasAbstract "A REGENERAÇÃO NATURAL É UM PROCESSO ECOLÓGICO COMPLEXO E MUITO IMPORTANTE QUE ENVOLVE DIVERSOS FATORES QUE CONTRIBUEM PARA A RECUPERAÇÃO DOS ECOSSISTEMAS FLORESTAIS TROPICAIS. ENTENDER COMO ESSES FATORES NATURAIS E ANTRÓPICOS AFETAM ESSE BIOMA ALTAMENTE PERTURBADO SERÁ UM GRANDE PASSO PARA SUA CONSERVAÇÃO E RESTAURAÇÃO. ASSIM, O OBJETIVO DESTE ESTUDO FOI INVESTIGAR OS EFEITOS DE PERTURBAÇÃOES ANTROPÓPICAS CRÔNICAS E FATORES AMBIENTAIS (ARIDEZ, FERTILIDADE DO SOLO E DISPONIBILIDADE DE LUZ VIA ÍND"@pt ;
    capes:hasDefenseDate "23FEB2022:00:00:00"^^xsd:date ;
    capes:hasTitle "IMPACT OF CHRONIC ANTHROPOGENIC DISTURBANCE AND ENVIRONMENTAL FACTORS ON NATURAL REGENERATION IN CAATINGA DRY FOREST"@pt ;
