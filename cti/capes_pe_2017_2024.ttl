    capes:isAuthoredBy <http://example.com/capes#author/RONALD_NOUTCHEU> ;
    capes:isFromProgram <http://example.com/capes#program/BIOLOGIA_VEGETAL> .

<http://example.com/capes#thesis/17224> a capes:Thesis ;
    capes:hasAbstract "THE OBJECTIVE OF THIS STUDY WAS TO EVALUATE THE INFLUENCE OF HYDRATION AND DEHYDRATION (HD CYCLES) ON SEEDS AND IRRIGATION CYCLES IN YOUNG PLANTS OF C. PYRAMIDALE ON THE RESPONSE TO WATER DEFICIT. NONE AND THREE HD CYCLES WERE PERFORMED ON THE SEEDS, THEN SEPARATED INTO THREE IRRIGATION GROUPS (DAILY, SEVEN AND FOURTEEN DAYS), FOR FIVE MONTHS AND AFTER BEING SUBJECTED TO IRRIGATION SUSPENSION. THE RESULTS DEMONSTRATED THAT REDUCTIONS IN THE RELATIVE WATER CONTENT PROMOTE INCREASES IN SUGARS (LEA"@pt ;
    capes:hasDefenseDate "25FEB2022:00:00:00"^^xsd:date ;
    capes:hasTitle "INFLUÊNCIA DA HIDRATAÇÃO DESCONTÍNUA DE SEMENTES E CICLOS DE REGA EM MUDAS DE CENOSTIGMA PYRAMIDALE (TUL.) E. GAGNON & G.P. LEWIS (FABACEAE) EM RESPOSTA AO DEFICIT HÍDRICO"@pt ;
