    capes:hasTitle "ASSOCIAÇÃO ENTRE NÍVEL DE ATIVIDADE FÍSICA E SINTOMAS DE DISFUNÇÃO TEMPOROMANDIBULAR EM TRABALHADORES DE ESCRITÓRIO"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
