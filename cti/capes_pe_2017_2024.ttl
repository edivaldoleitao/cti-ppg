    capes:isFromProgram <http://example.com/capes#program/GEOCIÊNCIAS> .

<http://example.com/capes#thesis/21613> a capes:Thesis ;
    capes:hasAbstract "THE LITHOSTRATIGRAPHIC UNIT OF INTEREST IN THIS WORK IS THE LATE BARREMIAN TO EARLY APTIAN MORRO DO CHAVES FORMATION (JIQUIÁ STAGE), FROM THE RIFT PHASE OF THE SERGIPE-ALAGOAS BASIN, CHARACTERIZED BY CALCARENITES AND CALCIRRUDITES INTERCALATED WITH CLAYSTONES, SHALES, SANDSTONES AND CONGLOMERATES. THE COQUINAS (BIOCLASTIC LIMESTONES) OF THE MORRO DO CHAVES FORMATION REPRESENT AN IMPORTANT CASE STUDY BECAUSE ARE ANALOGOUS ROCKS OF PRE-SALT CARBONATE RESERVOIRS. IN THIS WORK, CARBONATE ROCKS AND C"@pt ;
    capes:hasDefenseDate "28JUL2022:00:00:00"^^xsd:date ;
    capes:hasTitle "CARACTERIZAÇÃO PETROLÓGICA E GEOQUÍMICA DAS ROCHAS CARBONÁTICAS DA FORMAÇÃO MORRO DO CHAVES, BACIA DE SERGIPEALAGOAS, NE DO BRASIL"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
