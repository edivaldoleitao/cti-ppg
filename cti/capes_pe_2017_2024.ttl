    capes:hasDefenseDate "23FEB2022:00:00:00"^^xsd:date ;
    capes:hasTitle "AVALIAÇÃO DOS EFEITOS DOS PROCESSOS EROSIVOS E DE VULNERABILIDADE, E SUAS IMPLICAÇÕES AMBIENTAIS NO LITORAL DO MUNICÍPIO DO PAULISTA  PE"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
