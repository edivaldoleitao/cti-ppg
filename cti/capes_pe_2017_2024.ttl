        "USABILIDADE COMO FERRAMENTA DE FOMENTO DE MELHORIAS EM SITES DE GOVERNO ELETRÔNICO: UM ESTUDO DE CASO DO PORTAL PE CIDADÃO."@pt ;
    capes:hasYear "2017"^^xsd:gYear,
        "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/ISADORA_CAROLINA_CRESPO_PEREIRA>,
        <http://example.com/capes#author/RENATA_BALTAR_DA_SILVA> ;
