    capes:isFromProgram <http://example.com/capes#program/CIÊNCIA_POLÍTICA> .

<http://example.com/capes#thesis/6451> a capes:Thesis ;
    capes:hasAbstract "ACTIVITIES RELATED TO THE OIL AND ELECTRIC ENERGY SECTOR ARE MAINLY RESPONSIBLE FOR THE PRODUCTION OF OILY WATER AND ITS DISPOSAL, REQUIRING STRATEGIES FOR THE TREATMENT AND SEPARATION OF THESE RESIDUES. DISSOLVED AIR FLOTATION (DAF) IS ONE OF THE MOST USED WATER-OIL SEPARATION PROCESSES. THIS TECHNOLOGY USES MOSTLY CHEMICAL SURFACTANTS AS COLLECTORS TO ENHANCE THE SEPARATION OF OIL PARTICLES IN SUSPENSION. AS AN ALTERNATIVE TO SYNTHETIC AND TOXIC SURFACTANTS, THE USE OF BIOSURFACTANTS HAS STOOD"@pt ;
    capes:hasDefenseDate "27FEB2020:00:00:00"^^xsd:date ;
    capes:hasTitle "APLICAÇÃO DO BIOSSURFACTANTE DE BACILLUS METHYLOTROPHICUS UCP 1616 COMO COLETOR NO TRATAMENTO DE ÁGUAS OLEOSAS EM PROCESSOS DE FLOTAÇÃO"@pt ;
    capes:hasYear "2020"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/MARCOS_JOSE_CHAPRAO> ;
    capes:isFromProgram <http://example.com/capes#program/BIOTECNOLOGIA_-_REDE_RENORBIO> .

<http://example.com/capes#thesis/6456> a capes:Thesis ;
    capes:hasAbstract "NA REGIÃO DO XINGÓ, LOCALIZADA NO NORDESTE BRASILEIRO É ENCONTRADA A ESPÉCIE PARKINSONIA ACULEATA (CAESALPINIACEAE), ESPÉCIE NATURALIZADA NA REGIÃO QUE É UTILIZADA TRADICIONALMENTE PELA POPULAÇÃO LOCAL NO CONTROLE DE HIPERLIPIDEMIA E HIPERGLICEMIA. CONTUDO, POUCOS ESTUDOS APRESENTAM INFORMAÇÕES A RESPEITO DA SEGURANÇA DO USO DESTA ESPÉCIE. ESTE PRESENTE ESTUDO TEVE COMO OBJETIVO AVALIAR A EFICÁCIA/SEGURANÇA DA FRAÇÃO POLAR (FRPHEPA (2000 MG/KG), OBTIDO DAS PARTES AÉREAS DE PARKINSONIA ACULEATA, "@pt ;
    capes:hasDefenseDate "04DEC2020:00:00:00"^^xsd:date ;
