    capes:isFromProgram <http://example.com/capes#program/PRODUÇÃO_AGRÍCOLA> .

<http://example.com/capes#thesis/22708> a capes:Thesis ;
    capes:hasAbstract "THE TERM BIOCHAR WAS CONCEPTUALIZED FROM THE KNOWLEDGE OF THE TERRAS PRETAS DOS ÍNDIOS, BEING A SOLID MATERIAL RICH IN CARBON, WHICH HAS BEEN USED AS A SOIL CONDITIONER, AIMING TO IMPROVE ITS CHARACTERISTICS. THE USE OF SEWAGE SLUDGE FOR THE PRODUCTION OF BIOCHAR HAS BEEN A VIABLE ALTERNATIVE TO MANAGE THIS RESIDUE. THE OBJECTIVE OF THE PRESENT STUDY WAS TO EVALUATE THE IMPACT OF SEWAGE SLUDGE BIOCHAR (BLE) ON SOIL PHYSICAL AND CHEMICAL CHARACTERISTICS AND BEAN YIELD. THE EXPERIMENT WAS CARRIED "@pt ;
    capes:hasDefenseDate "27JUL2022:00:00:00"^^xsd:date ;
