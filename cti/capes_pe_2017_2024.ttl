    capes:isFromProgram <http://example.com/capes#program/BIOTECNOLOGIA_-_REDE_RENORBIO> .

<http://example.com/capes#thesis/6490> a capes:Thesis ;
    capes:hasAbstract "THE PRESENT THESIS WORK AIMED AT DEVELOPING A POWDER PRODUCT, BASED ON MICROCAPSULES, OF HIGH PROBIOTIC CONCENTRATION, WITH THE APPEAL OF IMMUNOMODULATORY POTENTIAL. INITIALLY, A SYSTEMATIC REVIEW OF IN VITRO ASSAYS AND CLINICAL TESTS WAS DESIGNED TO ASSESS PROBIOTICS' EFFICACY IN THE PROLIFERATION OF T CELLS IN HEALTHY INDIVIDUALS AND THEIR ADVERSE EFFECTS. THEN, AN IN VITRO STUDY WAS CARRIED OUT, WHERE SEVEN PROBIOTIC STRAINS OF DIFFERENT SPECIES OF THE GENUS BIFIDOBACTERIUM AND LACTOBACILLUS "@pt ;
    capes:hasDefenseDate "05MAR2020:00:00:00"^^xsd:date ;
