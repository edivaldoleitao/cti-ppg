    capes:hasYear "2017"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/ANA_MARLENE_ARDON_ESPINOZA> ;
    capes:isFromProgram <http://example.com/capes#program/ODONTOLOGIA> .

<http://example.com/capes#thesis/14489> a capes:Thesis ;
    capes:hasAbstract "TOPICAL FLUORIDE THERAPY IS CONSIDERED ONE OF THE MOST VALUABLE TOOLS IN THE MANAGEMENT OF DENTAL CARIES AND AMONG THE MATERIALS AVAILABLE, THE FLUORIDE VARNISH AND SILVER DIAMINE FLUORIDE HAVE EXCELLED. THE LITERATURE REPORTS VARIOUS CONCENTRATIONS AND DIFFERENT PROTOCOLS OF APPLICATION OF THESE CARIOSTATICS, BUT AVAILABLE REVIEWS DO NOT SHOW CLEAR RESULTS ABOUT THE PREVENTIVE FRACTION OF THESE MATERIALS BOTH IN THE PREVENTION OF NEW LESIONS AS IN ARRESTING OF THE DENTAL CARIES. FOR THIS REASON"@pt ;
    capes:hasDefenseDate "15MAR2017:00:00:00"^^xsd:date ;
    capes:hasTitle "FRAÇÃO PREVENTIVA DO DIAMINO FLUORETO DE PRATA E DOS VERNIZES FLUORETADOS EM DENTES DECÍDUOS - UM ESTUDO DE REVISÃO SISTEMÁTICA"@pt ;
