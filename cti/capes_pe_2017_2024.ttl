    capes:isAuthoredBy <http://example.com/capes#author/BRAULIO_DE_VILHENA_AMORIM_TOSTES> ;
    capes:isFromProgram <http://example.com/capes#program/CIÊNCIA_DOS_MATERIAIS> .

<http://example.com/capes#thesis/22692> a capes:Thesis ;
    capes:hasAbstract "THE USE OF BIOLOGICAL SUPPORTS CHEMICALLY MODIFIED WITH ANTIBACTERIAL AGENTS IS AN IMPORTANT ALTERNATIVE FOR THE TREATMENT OF INFECTIONS CAUSED BY BACTERIA RESISTANT TO CONVENTIONAL ANTIMICROBIALS. IN THIS DISSERTATION, WE PROPOSE THE SYNTHESIS AND CHARACTERIZATION OF ANTIBACTERIAL COMPOSITES BASED ON NILE TILAPIA SKIN COATED WITH CONDUCTIVE POLYMERS (POLYPYRROLE AND POLYANILINE) AND SILVER NANOPARTICLES (AGNPS). AGNPS WERE PREPARED BY GREEN SYNTHESIS USING REDUCING AGENTS BASED ON TEA TREE ESSE"@pt ;
    capes:hasDefenseDate "25FEB2022:00:00:00"^^xsd:date ;
    capes:hasTitle "ESTRATÉGIAS BASEADAS EM QUÍMICA VERDE PARA PRODUÇÃO DE ANTIBACTERIANOS LIVRES DE ANTIBIÓTICOS"@pt ;
    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/MILENA_LIMA_GUIMARAES> ;
    capes:isFromProgram <http://example.com/capes#program/CIÊNCIA_DOS_MATERIAIS> .

<http://example.com/capes#thesis/22693> a capes:Thesis ;
    capes:hasAbstract "GYPSUM IS A WHITE POWDER THAT REQUIRES A HYDRATION PROCESS TO BE USED. AFTER DRYING, THE GYPSUM FORMS A MICROSTRUCTURE IN THE SHAPE OF INTERTWINED NEEDLES WITH PORES, EXHIBITING ATTRACTIVE PROPERTIES FOR CIVIL CONSTRUCTION. HOWEVER, THIS BINDER ALSO HAS LIMITATIONS, SUCH AS ITS AFFINITY FOR WATER, WHICH LIMITS ITS APPLICATION IN EXTERNAL ENVIRONMENTS. THEREFORE, IN ENVIRONMENTS WITH HIGH HUMIDITY IT REFLECTS IN HIGH ABSORPTION, CONSEQUENTLY, REDUCING THE RESISTANCE TO COMPRESSION, FLEXION AND TR"@pt ;
    capes:hasDefenseDate "19DEC2022:00:00:00"^^xsd:date ;
