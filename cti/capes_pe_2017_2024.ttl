    capes:isFromProgram <http://example.com/capes#program/PATOLOGIA> .

<http://example.com/capes#thesis/1253> a capes:Thesis ;
    capes:hasAbstract "PHILADELPHIA (PH) NEGATIVE MYELOPROLIFERATIVE NEOPLASMS (MPN) MAINLY COMPRISE POLYCYTHEMIA VERA (PV), ESSENTIAL THROMBOCYTHEMIA (TE) AND MYELOFIBROSIS (MF). THESE ARE HAEMATOLOGICAL MALIGNANCIES THAT ARISE FROM THE CLONAL PROLIFERATION OF NEOPLASTIC STEM CELLS IN THE BONE MARROW AND SHARE COMMON PATHOPHYSIOLOGICAL AND CLINICAL FEATURES. MATRIX METALLOPROTEINASES, IN TURN, ARE PROTEOLYTIC ENZYMES CAPABLE OF REMODELING EXTRACELLULAR MATRIX (ECM) ACTIVATING CYTOKINES AND GROWTH FACTORS THAT ACT ON "@pt ;
    capes:hasDefenseDate "26AUG2019:00:00:00"^^xsd:date ;
    capes:hasTitle "ASSOCIAÇÃO DOS POLIMORFISMOS NOS GENES MMP2 E MMP9 COM CARACTERÍSTICAS CLÍNICAS E LABORATORIAIS DE PACIENTES COM NEOPLASIAS MIELOPROLIFERATIVAS"@pt ;
