    capes:hasTitle "CARACTERIZAÇÃO ESPECTRAL DE SKARNS MINERALIZADOS EM W-MO- VESUVIANITA: O EXEMPLO DO SKARN DE UMBUZEIRO DOCE (PB)"@pt ;
