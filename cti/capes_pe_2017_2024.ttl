    capes:isAuthoredBy <http://example.com/capes#author/ISABELA_SILVA_RIBEIRO> ;
    capes:isFromProgram <http://example.com/capes#program/BIOLOGIA_CELULAR_E_MOLECULAR_APLICADA> .

<http://example.com/capes#thesis/28481> a capes:Thesis ;
    capes:hasAbstract "THE RECENT COVID-19 PANDEMIC IN THE WORLD AND ITS DEVASTATING EFFECTS ON THE POPULATION, STIMULATED THE DEVELOPMENT OF RAPID, RELIABLE, SENSITIVE AND LOW-COST DIAGNOSTIC TESTS. THE GOLD STANDARD MOLECULAR METHOD FOR DIAGNOSING COVID-19 FROM NASOPHARYNGEAL SWAB SAMPLES FROM INFECTED PEOPLE IS THE REVERSE TRANSCRIPTASE REACTION FOLLOWED BY THE POLYMERASE CHAIN REACTION (RT-QPCR). HOWEVER, THE METHOD IS EXPENSIVE AND REQUIRES EQUIPMENT THAT LIMITS THE USE OF THE TECHNIQUE AT POINTS OF CARE IN THE M"@pt ;
    capes:hasDefenseDate "30AUG2022:00:00:00"^^xsd:date ;
    capes:hasTitle "DESENVOLVIMENTO DE UM KIT RÁPIDO DE BAIXO CUSTO BASEADO EM RT-LAMP-PCR PARA DETECÇÃO DO SARS-COV-2 (COVID-19)"@pt ;
