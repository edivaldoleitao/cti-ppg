    capes:isAuthoredBy <http://example.com/capes#author/ANA_GABRIELLE_DA_ROCHA_E_SILVA> ;
    capes:isFromProgram <http://example.com/capes#program/BIODIVERSIDADE_E_CONSERVAÇÃO> .

<http://example.com/capes#thesis/23872> a capes:Thesis ;
    capes:hasAbstract "EUPHORBIACEAE IS THE LARGEST FAMILY OF MALPIGHIALES (6,300 SPECIES), COMPRISING ABOUT 1,000 SPECIES IN BRAZIL (60% ENDEMIC), MAKING THE COUNTRY THE CENTER OF DIVERSITY OF THE GROUP. CONSIDERING THE WIDE DISTRIBUTION, NUMBER OF SPECIES AND ECONOMIC AND BIOLOGICAL IMPORTANCE OF EUPHORBIACEAE IN BRAZIL, THIS STUDY AIMED TO ANALYZE WHETHER THEAMOUNTOF PAPERS IS COMPATIBLE WITH THE REPRESENTATIVENESS OF THE FAMILY IN THE COUNTRY, TO UNDERSTAND WHAT ARE THE GAPS IN THE KNOWLEDGE OF THE FAMILY AND WHAT"@pt ;
    capes:hasDefenseDate "31MAR2022:00:00:00"^^xsd:date ;
