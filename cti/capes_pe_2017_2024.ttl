    capes:isFromProgram <http://example.com/capes#program/BIOTECNOLOGIA_-_REDE_RENORBIO> .

<http://example.com/capes#thesis/6555> a capes:Thesis ;
    capes:hasAbstract "AEDES AEGYPTI IS THE MOSQUITO THAT TRANSMITS THE DENGUE, ZIKA AND CHIKUNGUNYA ARBOVIRUSES, BY WHICH IT IS ESTIMATED THAT ONE IN THREE PEOPLE IN THE WORLD CAN BECOME INFECTED. SINCE THERE IS NO VACCINE AGAINST THESE THREE ARBOVIRUSES, THEIR CONTROL IS BASED MAINLY ON VECTOR CONTROL. HOWEVER, CHALLENGES SUCH AS THE GROWING RESISTANCE TO INSECTICIDES IN POPULATIONS OF AE. AEGYPTI EXPOSE THE NEED TO SEARCH FOR NEW TECHNOLOGIES THAT CAN COMPLEMENT THE TRADITIONAL MOSQUITO VECTOR CONTROL TOOLS. GIVEN "@pt ;
    capes:hasDefenseDate "10SEP2020:00:00:00"^^xsd:date ;
