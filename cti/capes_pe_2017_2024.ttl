    capes:hasDefenseDate "06FEB2017:00:00:00"^^xsd:date ;
    capes:hasTitle "ANALISE DOS POLIMORFISMOS DA B - DEFENSINA - 1 EM DIABÉTICOS TIPO 2 COM PERIODONTITE CRONICA"@pt ;
    capes:hasYear "2017"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/FELIPE_RODRIGUES_DE_ALMEIDA> ;
    capes:isFromProgram <http://example.com/capes#program/ODONTOLOGIA> .

<http://example.com/capes#thesis/10185> a capes:Thesis ;
    capes:hasAbstract "INTRODUCTION: THE RATES OF DETECTION AND LATE DIAGNOSIS OF HUMAN IMMUNODEFICIENCY VIRUS IN THE ELDERLY POPULATION HAVE BEEN INCREASING OVER THE YEARS. THIS INCREASE MAY BE DUE TO THE STEREOTYPE THAT THE ELDERLY ARE ASEXUAL, AS WELL AS THE INVISIBILITY OF SEXUAL ACTIVITY BY HEALTH PROFESSIONALS AND THE PREJUDICE AGAINST SUCH PRACTICES IN THE ELDERLY, MAKING OLDER PEOPLE MORE VULNERABLE TO SEXUALLY TRANSMITTED INFECTIONS AND HIV. OBJECTIVES: TO ANALYZE THE KNOWLEDGE ABOUT HIV / AIDS AND THE AFFECT"@pt ;
