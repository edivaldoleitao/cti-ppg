    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/LAIZA_DE_OLIVEIRA_LUCENA> ;
    capes:isFromProgram <http://example.com/capes#program/GERONTOLOGIA> .

<http://example.com/capes#thesis/18775> a capes:Thesis ;
    capes:hasAbstract "THE RESEARCH AIMS TO UNDERSTAND THE BEHAVIOR OF THE ELDERLY IN FACE OF FALSE NEWS ABOUT HEALTH RECEIVED BY VIRTUAL SOCIAL NETWORKS. THIS IS A QUALITATIVE STUDY OF DESCRIPTIVE AND EXPLORATORY CHARACTER THAT WILL USE OPEN SEMI-STRUCTURED INTERVIEW AS A TECHNIQUE. PARTICIPANTS WERE SELECTED FROM AMONG THE ELDERLY PARTICIPATING IN THE ONLINE COURSE OFFERED BY THE OPEN UNIVERSITY FOR THE ELDERLY (UNATI) OF THE FEDERAL UNIVERSITY OF PERNAMBUCO (UFPE). THE TOTAL NUMBER OF ELDERLY PEOPLE WAS DEFINED BY "@pt ;
    capes:hasDefenseDate "10FEB2022:00:00:00"^^xsd:date ;
