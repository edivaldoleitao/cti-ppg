    capes:hasYear "2022"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/MARINA_PENHA_ABREU_CASSIMIRO> ;
    capes:isFromProgram <http://example.com/capes#program/GERONTOLOGIA> .

<http://example.com/capes#thesis/18776> a capes:Thesis ;
    capes:hasAbstract "EDUCATIONAL TECHNOLOGY IS AN INNOVATIVE STRATEGY CAPABLE OF ENCOURAGING THE ELDERLY TO ADOPT PREVENTIVE HEALTH BEHAVIORS. RECOGNIZING THE IMPORTANCE OF THE USE OF EDUCATIONAL TECHNOLOGIES FOCUSED ON THE PREVENTION OF FALLS, THE STUDY AIMED TO DESCRIBE THE PROCESS OF CONSTRUCTION AND VALIDATION OF AN EDUCATIONAL GAME FOR THE PREVENTION OF FALLS IN THE ELDERLY. IT IS A METHODOLOGICAL RESEARCH OF THE TYPE OF DEVELOPMENT. THE EDUCATIONAL GAME ENTITLED &QUOT;WHAT TO DO NOT TO FALL&QUOT; WAS ELABORATE"@pt ;
