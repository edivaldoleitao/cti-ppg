    capes:isAuthoredBy <http://example.com/capes#author/CLARIOVALDO_ENIAS_TAVARES_DA_SILVA> ;
    capes:isFromProgram <http://example.com/capes#program/CIÊNCIAS_CONTÁBEIS> .

<http://example.com/capes#thesis/6897> a capes:Thesis ;
    capes:hasAbstract "OS TRIBUNAIS DE CONTAS, ATRAVÉS DE SUAS AÇÕES, VÊM AUXILIANDO OS PODERES LEGISLATIVOS NO EXERCÍCIO DO CONTROLE EXTERNO, AGINDO NO COMBATE ÀS IRREGULARIDADES PARA MAIOR EFICIÊNCIA DOS GASTOS PÚBLICOS. BUSCA-SE NESTE ESTUDO O APRENDIZADO - ATRAVÉS DA DISSECAÇÃO DOS RELATÓRIOS DO TCE-PE, SOBRE A AVALIAÇÃO DAS PRESTAÇÕES DE CONTAS DOS MUNICÍPIOS PERNAMBUCANOS - QUE PERMITA IDENTIFICAR AS PRINCIPAIS FRAQUEZAS MATERIAIS E EXPLORÁ-LAS DE MANEIRA QUALITATIVA. PARA CADA MUNICÍPIO FORAM ANALISADOS RELATÓR"@pt ;
    capes:hasDefenseDate "21FEB2017:00:00:00"^^xsd:date ;
    capes:hasTitle "DISSECANDO OS RELATÓRIOS DO TCE-PE DE AVALIAÇÃO DAS PRESTAÇÕES DE CONTAS DOS MUNICÍPIOS PERNAMBUCANOS: UMA ANÁLISE EXPLORATÓRIA"@pt ;
    capes:hasYear "2017"^^xsd:gYear ;
    capes:isAuthoredBy <http://example.com/capes#author/ANDERSON_DO_NASCIMENTO_OLIVEIRA> ;
